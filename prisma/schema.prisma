generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Inquiry {
  id        String   @id @default(cuid())
  company   String
  name      String
  phone     String
  email     String?
  category  String
  message   String
  status    String   @default("NEW")
  createdAt DateTime @default(now())
}

model SiteSetting {
  key   String @id
  value String
}

model HistoryEntry {
  id    String   @id @default(cuid())
  year  String
  title String
  items String[]
  order Int
}

model SolutionCard {
  id       String   @id @default(cuid())
  category String
  client   String
  title    String
  desc     String
  tags     String[]
  imageUrl String
  order    Int
}
